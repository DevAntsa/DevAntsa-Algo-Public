# ============================================================
# DevAntsa Lab .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# --- Environment ---
.env
.env.*
!.env_example

# --- Runtime data (regenerated by the system) ---
live_trading/data/state.json
live_trading/data/trades.csv
live_trading/data/*.json
live_trading/data/*.csv

# --- OHLCV data (too large, downloaded separately) ---
rbi_full_data/*.csv
RBI_FullData/
DevAntsa_Lab/RBI_Agents/RBI_Bear/rbi_regime_bear/
DevAntsa_Lab/RBI_Agents/RBI_Bull/rbi_regime_bull/
DevAntsa_Lab/RBI_Agents/RBI_Bull/rbi_regime_bull_full/

# --- RBI daily run outputs (regenerated each batch) ---
RBI_Regular/data/
RBI_Bear/data/
RBI_Bull/data/
RBI_Sideways/data/
RBI_Regular/results/
RBI_Regular/results_bear/
RBI_Regular/results_sideways/

# --- Temp files ---
nul
*.tmp
tmpclaude-*
*.log

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- OS ---
Thumbs.db
.DS_Store
desktop.ini

# --- Large binary files ---
*.zip
*.tar.gz
*.pkl
*.h5
*.model
